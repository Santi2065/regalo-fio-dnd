{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:read-files",
    "fs:write-files",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-remove",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
